# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit real keys.

# Google AI Studio (free tier: Gemini 2.5 Flash). Get one at aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# Groq (free tier). Get one at console.groq.com
GROQ_API_KEY=your_groq_key_here

# Picovoice Porcupine (wake word). Get one at console.picovoice.ai
PORCUPINE_ACCESS_KEY=your_picovoice_key_here
